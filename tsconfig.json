{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"lib": ["ES2022", "DOM"],
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"isolatedDeclarations": true,
		"verbatimModuleSyntax": true,
		"rootDir": "src",
		"outDir": "dist"
	},
	"include": ["src/**/*"]
}
